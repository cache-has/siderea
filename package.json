{
  "name": "siderea",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "npm run build:wasm && vite dev",
    "build:wasm": "wasm-pack build crates/wasm-bridge --target web --out-dir ../../src/lib/wasm && wasm-opt -Oz --enable-bulk-memory --enable-nontrapping-float-to-int --enable-sign-ext --enable-mutable-globals src/lib/wasm/wasm_bridge_bg.wasm -o src/lib/wasm/wasm_bridge_bg.wasm",
    "build:tle": "node scripts/fetch-tle.mjs",
    "build:data": "python3 scripts/process-hyg.py && cp data/curated/notable-objects.json static/data/notable-objects.json && python3 scripts/validate-notable-objects.py",
    "fetch:textures": "node scripts/fetch-textures.mjs",
    "build:textures": "node scripts/process-textures.mjs",
    "build": "npm run build:wasm && npm run build:data && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^25.5.0",
    "@types/three": "^0.183.1",
    "eslint": "^10.1.0",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "three": "^0.183.2"
  }
}
