# Rust
target/

# Node
node_modules/

# Build outputs
dist/
build/
pkg/

# SvelteKit
.svelte-kit/

# WASM build output (regenerated by wasm-pack)
src/lib/wasm/

# OS
.DS_Store

# Raw data (downloaded, not committed — regenerate with scripts/process-hyg.py)
data/raw/

# Source texture downloads (large files — regenerate with npm run fetch:textures)
data/textures-source/

# Processed texture LOD tiers (regenerate with npm run build:textures)
static/textures/

# Processed data artifacts (regenerated from raw sources)
static/data/

# Environment
.env
.env.*
!.env.example
